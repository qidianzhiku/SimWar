APP_NAME=simwar
APP_ENV=development
LOG_LEVEL=debug

API_PORT=3000
TEACHER_WEB_PORT=3001
STUDENT_WEB_PORT=3002
ADMIN_WEB_PORT=3003
SIMWAR_STORE_FILE=tmp/simwar-store.json

DATABASE_URL=postgresql://simwar:simwar@localhost:5432/simwar
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-local-development-secret
INTERNAL_SERVICE_TOKEN=replace-with-local-internal-token

SIMULATION_CORE_MODE=mock
AI_PROVIDER=mock
AI_ADVISORY_ONLY=true
