{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simwar.local/schemas/m1-public-replay-evidence.v1.json",
  "title": "M1PublicReplayEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_semantics_version",
    "evidence_kind",
    "manifest_id",
    "manifest_hash",
    "manifest_version",
    "source_result_id",
    "canonical_evidence_digest",
    "replay_status",
    "replay_result_hash",
    "replay_writes_formal_results",
    "frozen_inputs"
  ],
  "properties": {
    "evidence_semantics_version": {
      "const": "m1-json-replay-evidence.v1"
    },
    "evidence_kind": {
      "const": "m1_json_runtime_replay_evidence"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "manifest_version": {
      "const": "run-manifest.v1"
    },
    "source_result_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_evidence_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "replay_status": {
      "type": "string",
      "enum": ["matched", "mismatched", "failed"]
    },
    "replay_result_hash": {
      "type": "string",
      "minLength": 1
    },
    "replay_writes_formal_results": {
      "const": false
    },
    "frozen_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "course_id",
        "run_id",
        "round_id",
        "round_no",
        "scenario_package_id",
        "parameter_set_id",
        "seed",
        "engine_id",
        "decision_batch_hash"
      ],
      "properties": {
        "course_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "round_id": {
          "type": "string",
          "minLength": 1
        },
        "round_no": {
          "type": "integer",
          "minimum": 1
        },
        "scenario_package_id": {
          "type": "string",
          "minLength": 1
        },
        "parameter_set_id": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer"
        },
        "engine_id": {
          "type": "string",
          "minLength": 1
        },
        "decision_batch_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
