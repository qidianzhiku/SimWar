{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simwar.local/contracts/schemas/student-role-assignment.v1.json",
  "title": "StudentRoleAssignment",
  "type": "object",
  "required": [
    "assignment_id",
    "tenant_id",
    "course_id",
    "run_id",
    "team_id",
    "user_id",
    "role_key",
    "role_template_id",
    "status",
    "source",
    "assigned_by",
    "assigned_at"
  ],
  "properties": {
    "assignment_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "course_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "team_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "role_key": {
      "type": "string",
      "enum": ["CEO", "CFO", "CMO", "COO"]
    },
    "role_template_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "inactive"]
    },
    "source": {
      "type": "string",
      "enum": ["teacher_assigned", "seeded_default"]
    },
    "assigned_by": { "type": "string", "minLength": 1 },
    "assigned_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
