{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simwar.local/contracts/schemas/decision-merge-commit.v1.json",
  "title": "DecisionMergeCommit",
  "type": "object",
  "required": [
    "merge_commit_id",
    "tenant_id",
    "run_id",
    "round_id",
    "team_id",
    "status",
    "source_section_ids",
    "merged_payload",
    "created_by",
    "created_at"
  ],
  "properties": {
    "merge_commit_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "round_id": { "type": "string", "minLength": 1 },
    "team_id": { "type": "string", "minLength": 1 },
    "status": { "const": "validated" },
    "source_section_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "merged_payload": { "$ref": "decision-payload.v1.json" },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
