{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simwar.local/contracts/schemas/role-context.v1.json",
  "title": "RoleContext",
  "type": "object",
  "required": [
    "role_context_id",
    "tenant_id",
    "user_id",
    "course_id",
    "run_id",
    "round_id",
    "round_no",
    "team_id",
    "assignment_id",
    "role_key",
    "role_template_id",
    "permissions",
    "source",
    "expires_at"
  ],
  "properties": {
    "role_context_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "course_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "round_id": { "type": "string", "minLength": 1 },
    "round_no": { "type": "integer", "minimum": 1 },
    "team_id": { "type": "string", "minLength": 1 },
    "assignment_id": { "type": "string", "minLength": 1 },
    "role_key": {
      "type": "string",
      "enum": ["CEO", "CFO", "CMO", "COO"]
    },
    "role_template_id": { "type": "string", "minLength": 1 },
    "permissions": { "$ref": "role-permission-policy.v1.json" },
    "source": { "const": "resolved_from_assignment" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
