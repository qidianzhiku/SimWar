{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simwar.local/contracts/schemas/plugin-manifest.v1.json",
  "title": "PluginManifest",
  "type": "object",
  "required": [
    "manifest_version",
    "plugin_id",
    "name",
    "version",
    "status",
    "industry",
    "supported_hooks",
    "parameter_schema_version",
    "parameter_schema_ref",
    "settlement_hook_refs",
    "adapter_ref"
  ],
  "properties": {
    "manifest_version": { "const": "1.0.0" },
    "plugin_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "candidate", "shadow_passed", "approved", "deprecated"]
    },
    "industry": { "const": "wellness" },
    "supported_hooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["adjustDemand", "adjustOperations", "adjustFinance", "adjustScore"]
      },
      "uniqueItems": true
    },
    "parameter_schema_version": { "type": "string", "minLength": 1 },
    "parameter_schema_ref": { "type": "string", "minLength": 1 },
    "settlement_hook_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "adapter_ref": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
